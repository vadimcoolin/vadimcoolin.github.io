---
import Footer from "../components/ui/Footer.astro";
import StickyNav from "../components/ui/StickyNav.astro";
import { footerSection, stickyNavSection } from "../data/global";
import type {
  FooterSectionContent,
  StickyNavSectionContent,
} from "../data/types";
import MainLayout from "./MainLayout.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  stickyNavContent?: StickyNavSectionContent;
  footerContent?: FooterSectionContent;
  footerSimple?: boolean;
}

const {
  title,
  description,
  ogImage,
  ogType,
  canonicalUrl,
  stickyNavContent = stickyNavSection,
  footerContent = footerSection,
  footerSimple = false,
} = Astro.props;
---

<MainLayout title={title} description={description} ogImage={ogImage} ogType={ogType} canonicalUrl={canonicalUrl}>
  <main id="main" tabindex="-1" class="flex min-h-dvh flex-col">
    <StickyNav content={stickyNavContent} />
    <div class="flex flex-1 flex-col">
      <slot />
    </div>
    <Footer content={footerContent} simple={footerSimple} />
  </main>
</MainLayout>
