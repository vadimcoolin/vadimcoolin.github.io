---
import Button from "./Button.astro";
import type { StickyNavSectionContent } from "../../data/types";

interface Props {
  content: StickyNavSectionContent;
}

const { content } = Astro.props;

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const normalizedPath =
  Astro.url.pathname.replace(/\/index\.html$/i, "").replace(/\/$/, "") || "/";

const isHome = normalizedPath === baseUrl || normalizedPath === "/";

const isActive = (href: string) => {
  if (href.startsWith("#")) return false;
  const linkPath = href.replace(/\/$/, "") || "/";
  const fullPath = (baseUrl + linkPath).replace(/\/$/, "") || "/";
  return normalizedPath === linkPath || normalizedPath === fullPath;
};

const resolveHref = (href: string) => {
  if (href.startsWith("#")) {
    if (isHome) return href;
    return `${baseUrl}${href}`;
  }
  return `${baseUrl}${href}`;
};
---

<nav
  id="site-nav"
  aria-label="Primary"
  class="fixed inset-x-0 top-0 z-50"
>
  <div class="nav-inner">
    <a href={resolveHref("/")} class="nav-brand">
      {content.brandName}
    </a>

    <div class="nav-links">
      {content.links.map((link) => (
        <a
          href={resolveHref(link.href)}
          class:list={["nav-link", { "nav-link--active": isActive(link.href) }]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="nav-actions">
      {content.cta && (
        <a href={resolveHref(content.cta.href)} class="nav-cta">
          {content.cta.showStatus && <span class="status-dot"></span>}
          {content.cta.label}
        </a>
      )}
    </div>

    <button
      id="mobile-nav-toggle"
      class="nav-burger"
      aria-expanded="false"
      aria-controls="mobile-nav-panel"
      aria-label="Open menu"
    >
      <span class="burger" aria-hidden="true">
        <span class="burger__line burger__line--top"></span>
        <span class="burger__line burger__line--middle"></span>
        <span class="burger__line burger__line--bottom"></span>
      </span>
    </button>
  </div>
</nav>

<div
  id="mobile-nav-panel"
  class="mobile-nav-panel"
  aria-hidden="true"
>
  <div class="mobile-nav-content">
    <div class="mobile-nav-links">
      {content.links.map((link) => (
        <a href={resolveHref(link.href)} class="mobile-nav-link">
          {link.label}
        </a>
      ))}
    </div>
    {content.cta && (
      <a href={resolveHref(content.cta.href)} class="mobile-nav-cta">
        {content.cta.showStatus && <span class="status-dot"></span>}
        {content.cta.label}
      </a>
    )}
  </div>
</div>

<style>
  #site-nav {
    transition: background-color 420ms ease-out, transform 0.35s ease;
  }

  #site-nav.nav-hidden {
    transform: translateY(-100%);
  }

  #site-nav.is-scrolled {
    background-color: color-mix(in srgb, var(--color-bg) 92%, transparent);
    backdrop-filter: blur(12px);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px;
    max-width: 100%;
  }

  .nav-brand {
    font-family: var(--font-heading);
    font-size: clamp(0.875rem, 1.25vw, 24px);
    font-weight: 800;
    text-decoration: none;
    color: var(--color-text);
    white-space: nowrap;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: clamp(0.75rem, 0.83vw, 16px);
    font-weight: 500;
    text-decoration: none;
    color: var(--color-text);
    letter-spacing: 0.02em;
    position: relative;
    line-height: 1;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1px;
    background: var(--color-text);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .nav-link:hover::after {
    transform: scaleX(1);
  }

  .nav-actions {
    display: flex;
    align-items: center;
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading);
    font-size: clamp(0.875rem, 1.25vw, 24px);
    font-weight: 800;
    text-decoration: none;
    color: var(--color-text);
    transition: opacity 0.2s ease;
  }

  .nav-cta:hover {
    opacity: 0.7;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.15; }
  }

  .status-dot {
    display: inline-block;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background-color: #22c55e;
    flex-shrink: 0;
    animation: blink 2s ease-in-out infinite;
  }

  .nav-burger {
    display: none;
    position: relative;
    width: 2.75rem;
    height: 2.75rem;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
  }

  @media (max-width: 768px) {
    .nav-inner {
      padding: 16px;
    }

    .nav-links,
    .nav-actions {
      display: none;
    }

    .nav-burger {
      display: flex;
    }
  }

  @media (max-width: 480px) {
    .nav-inner {
      padding: 12px;
    }
  }

  .burger {
    position: relative;
    display: block;
    width: 1.5rem;
    height: 1.5rem;
  }

  .burger__line {
    position: absolute;
    left: 0;
    width: 100%;
    height: 0.0625rem;
    background: var(--color-text);
    transform-origin: center;
    transition: transform 0.24s ease, opacity 0.2s ease;
    top: calc(50% - 0.03125rem);
  }

  .burger__line--top { transform: translateY(var(--icon-offset, 0.375rem)); }
  .burger__line--middle { opacity: 1; }
  .burger__line--bottom { transform: translateY(calc(var(--icon-offset, 0.375rem) * -1)); }

  #mobile-nav-toggle.is-open .burger__line--top { transform: translateY(0) rotate(135deg); }
  #mobile-nav-toggle.is-open .burger__line--middle { opacity: 0; }
  #mobile-nav-toggle.is-open .burger__line--bottom { transform: translateY(0) rotate(225deg); }

  .mobile-nav-panel {
    position: fixed;
    inset: 0;
    z-index: 45;
    background: var(--color-bg);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.2s ease-out;
  }

  .mobile-nav-panel.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .mobile-nav-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100dvh;
    gap: 2.5rem;
    padding: 24px;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .mobile-nav-link {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  .mobile-nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--color-text);
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--color-text);
    border-radius: var(--radius-button);
  }

  :global(.mobile-nav-open) { overflow: hidden; }

  @media (prefers-reduced-motion: reduce) {
    .burger__line, .mobile-nav-panel { transition-duration: 0.01ms; }
  }
</style>

<script>
  const nav = document.getElementById("site-nav");
  const toggle = document.getElementById("mobile-nav-toggle");
  const panel = document.getElementById("mobile-nav-panel");
  const panelLinks = panel?.querySelectorAll("a") ?? [];
  let isMenuOpen = false;

  const setMenuState = (open) => {
    if (!toggle || !panel) return;
    isMenuOpen = open;
    toggle.classList.toggle("is-open", open);
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    panel.classList.toggle("is-open", open);
    panel.setAttribute("aria-hidden", String(!open));
    document.body.classList.toggle("mobile-nav-open", open);
  };

  toggle?.addEventListener("click", () => setMenuState(!isMenuOpen));
  panelLinks.forEach((link) => link.addEventListener("click", () => setMenuState(false)));
  window.addEventListener("keydown", (e) => { if (e.key === "Escape") setMenuState(false); });

  let lastScrollY = window.scrollY;
  const updateNavBackground = () => {
    if (!nav) return;
    nav.classList.toggle("is-scrolled", window.scrollY > 8);
    lastScrollY = window.scrollY;
  };
  updateNavBackground();
  window.addEventListener("scroll", updateNavBackground, { passive: true });

  const footer = document.querySelector("footer");
  if (footer) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        nav?.classList.toggle("nav-hidden", entry.isIntersecting);
      },
      { rootMargin: "0px 0px -50% 0px" }
    );
    observer.observe(footer);
  }
</script>
