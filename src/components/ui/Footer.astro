---
import type { FooterSectionContent } from "../../data/types";

interface Props {
  content: FooterSectionContent;
  simple?: boolean;
}

const { content, simple } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const normalizedPath =
  Astro.url.pathname.replace(/\/index\.html$/i, "").replace(/\/$/, "") || "/";
const isHome = normalizedPath === baseUrl;
const logoUrl = baseUrl + "/images/coolin-logo.svg";

const resolveHref = (href: string) => {
  if (href.startsWith("http")) return href;
  if (href.startsWith("#")) {
    if (isHome) return href;
    return `${baseUrl}${href}`;
  }
  return `${baseUrl}${href}`;
};

const isExternal = (href: string) => href.startsWith("http");
---

<footer class:list={["footer", simple ? "footer--simple" : "footer--default"]}>
  {!simple && (
    <div class="footer-row">
      <div class="footer-cols">
        <nav class="footer-nav" aria-label="Footer navigation">
          {content.columns.sitemap.map((link) => (
            <a
              href={resolveHref(link.href)}
              class="footer-link"
              target={isExternal(link.href) ? "_blank" : undefined}
              rel={isExternal(link.href) ? "noopener noreferrer" : undefined}
            >
              {link.label}
            </a>
          ))}
        </nav>
        <nav class="footer-nav" aria-label="Portfolio links">
          {content.columns.portfolio.map((link) => (
            <a
              href={resolveHref(link.href)}
              class="footer-link"
              target="_blank"
              rel="noopener noreferrer"
            >
              {link.label}
            </a>
          ))}
        </nav>
        <nav class="footer-nav" aria-label="Social media links">
          {content.columns.social.map((link) => (
            <a
              href={resolveHref(link.href)}
              class="footer-link"
              target="_blank"
              rel="noopener noreferrer"
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
      <p class="footer-copyright">&copy;2026 Vadim Coolin. All rights reserved.</p>
    </div>
  )}
</footer>

<div class="footer-logo-fixed" id="footer-logo-fixed">
  <img src={logoUrl} alt="" class="footer-logo-img" />
</div>

<div class="footer-scroll-buffer" id="footer-scroll-buffer"></div>

<style>
  .footer {
    padding: 0 24px;
  }

  .footer--default {
    margin-top: 96px;
  }

  .footer--simple {
    margin-top: 0;
  }

  .footer-row {
    display: flex;
    justify-content: space-between;
    border-top: 1px solid var(--color-text);
    padding-top: 48px;
  }

  .footer-cols {
    display: flex;
    gap: 0;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 200px;
  }

  .footer-link {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    position: relative;
    line-height: 1;
    display: inline-block;
    width: fit-content;
  }

  .footer-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1px;
    background: var(--color-text);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .footer-link:hover::after {
    transform: scaleX(1);
  }

  .footer-copyright {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    color: var(--color-text);
    margin: 0;
    white-space: nowrap;
  }

  .footer-logo-fixed {
    position: fixed;
    bottom: 24px;
    left: 24px;
    width: calc(100% - 48px);
    height: 0;
    z-index: 10;
    pointer-events: none;
    transform-origin: 50% 100%;
    transform: scaleY(0);
    will-change: transform;
  }

  .footer-logo-img {
    width: 100%;
    height: 100%;
    display: block;
  }

  .footer-scroll-buffer {
    height: 250px;
    pointer-events: none;
  }

  @media (max-width: 1024px) {
    .footer-nav {
      width: 160px;
    }

    .footer-cols {
      gap: 8px;
    }
  }

  @media (max-width: 768px) {
    .footer-row {
      flex-direction: column;
      gap: 48px;
    }

    .footer-nav {
      width: auto;
      min-width: 140px;
    }

    .footer-copyright {
      white-space: normal;
    }
  }

  @media (max-width: 480px) {
    .footer-cols {
      flex-direction: column;
      gap: 32px;
    }
  }
</style>

<script>
  (function () {
    var fixed = document.getElementById("footer-logo-fixed");
    var buffer = document.getElementById("footer-scroll-buffer");
    if (!fixed || !buffer) return;

    var BUFFER_HEIGHT = 250;
    var logoHeight = 0;

    function calcHeight() {
      var w = fixed.offsetWidth;
      if (w <= 0) w = window.innerWidth;
      logoHeight = Math.max(1, Math.round(w * 378 / 1873));
      fixed.style.height = logoHeight + "px";
    }

    function onScroll() {
      var bufferTop = buffer.offsetTop;
      var viewportBottom = window.scrollY + window.innerHeight;
      var progress = Math.max(0, Math.min(1, (viewportBottom - bufferTop) / BUFFER_HEIGHT));
      if (progress > 0.98) progress = 1;
      fixed.style.transform = "scaleY(" + progress + ")";
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", function () {
      calcHeight();
      onScroll();
    }, { passive: true });

    calcHeight();
    onScroll();
  })();
</script>
