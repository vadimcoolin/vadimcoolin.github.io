---
export interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  /** Base URL for absolute links (default: https://example.com) */
  baseUrl?: string;
}

const { items, baseUrl = "https://example.com" } = Astro.props;

const visibleItems = items.slice(0, -1);
const allItems = items;
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol class="breadcrumbs__list">
    {visibleItems.map((item, i) => (
      <li class="breadcrumbs__item">
        {item.href ? (
          <a class="breadcrumbs__link" href={item.href}>{item.label}</a>
        ) : (
          <span class="breadcrumbs__link">{item.label}</span>
        )}
        {i < visibleItems.length - 1 && (
          <span class="breadcrumbs__sep" aria-hidden="true">/</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": allItems.map((item, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": item.label,
    ...(item.href ? { "item": item.href.startsWith("http") ? item.href : `${baseUrl}${item.href}` } : {}),
  })),
})} />

<style lang="scss">
  .breadcrumbs { margin: 0; }
  .breadcrumbs__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    color: var(--color-text-muted);
  }
  .breadcrumbs__item { display: flex; align-items: center; gap: 0.4rem; }
  .breadcrumbs__link {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 120ms;
    &:hover { color: var(--color-text); }
  }
  .breadcrumbs__sep { font-size: 0.7rem; opacity: 0.5; line-height: 1; }
</style>
