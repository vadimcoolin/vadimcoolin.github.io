---
type SectionTag = "section" | "header" | "footer";
type TopSpacing = "none" | "small" | "full";
type SectionSurface = "transparent" | "muted" | "dark" | "image";
type BackgroundSource = {
  srcSet: string;
  media?: string;
  type?: string;
  sizes?: string;
};

type BackgroundMedia = {
  src: string;
  srcSet?: string;
  sizes?: string;
  sources?: BackgroundSource[];
  loading?: "lazy" | "eager";
  fetchPriority?: "high" | "low" | "auto";
  class?: string;
};

interface Props {
  as?: SectionTag;
  id?: string;
  topSpacing?: TopSpacing;
  surface?: SectionSurface;
  backgroundMedia?: BackgroundMedia;
  container?: boolean;
  class?: string;
  containerClass?: string;
}

const {
  as: Tag = "section",
  id,
  topSpacing = "full",
  surface = "transparent",
  backgroundMedia,
  container = true,
  class: className = "",
  containerClass = "",
} = Astro.props;

const topSpacingClasses: Record<TopSpacing, string> = {
  none: "pt-0",
  small: "pt-[4.6667rem] md:pt-28",
  full: "pt-[7.1667rem] md:pt-[10.75rem]",
};

const surfaceClasses: Record<SectionSurface, string> = {
  transparent: "",
  muted: "bg-[color:var(--color-surface)]",
  dark: "bg-[color:var(--color-surface-strong)] text-white",
  image: "relative overflow-hidden",
};
---

<Tag
  id={id}
  class:list={["mb-0 pb-0", topSpacingClasses[topSpacing], surfaceClasses[surface], className]}
>
  {
    surface === "image" && backgroundMedia && (
      <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
        <picture>
          {
            backgroundMedia.sources?.map((source) => (
              <source
                srcset={source.srcSet}
                media={source.media}
                type={source.type}
                sizes={source.sizes}
              />
            ))
          }
          <img
            src={backgroundMedia.src}
            srcset={backgroundMedia.srcSet}
            sizes={backgroundMedia.sizes}
            loading={backgroundMedia.loading ?? "lazy"}
            fetchpriority={backgroundMedia.fetchPriority}
            alt=""
            class:list={["h-full w-full object-cover", backgroundMedia.class]}
          />
        </picture>
      </div>
    )
  }
  <div class="relative z-10">
    {
      container ? (
        <div class:list={["container", containerClass]}>
          <slot />
        </div>
      ) : (
        <slot />
      )
    }
  </div>
  
</Tag>

<style>
  section[id] {
    scroll-margin-top: 96px;
  }
</style>
