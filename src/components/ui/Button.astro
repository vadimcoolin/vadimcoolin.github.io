---
import styles from "./Button.module.scss";

interface Props {
  href?: string;
  variant?: "primary" | "default";
  class?: string;
  type?: "button" | "submit";
  target?: string;
  rel?: string;
  /** When set, opens the modal `<dialog id={dialogOpen}>` (see `Popup` external triggers). */
  dialogOpen?: string;
}

const {
  href,
  variant = "default",
  class: className = "",
  type = "button",
  target,
  rel,
  dialogOpen,
} = Astro.props;

const classes = [styles.button, styles[variant], className];
const anchorRel = rel ?? (target === "_blank" ? "noopener noreferrer" : undefined);
---

{
  href ? (
    <a href={href} class:list={classes} target={target} rel={anchorRel}>
      <slot />
    </a>
  ) : (
    <button type={type} class:list={classes} {...dialogOpen ? ({ "data-dialog-open": dialogOpen } as const) : {}}>
      <slot />
    </button>
  )
}
