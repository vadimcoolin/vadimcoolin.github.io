---
import type { CaseStudyEntry } from "../../data/types";

interface Props {
  content: CaseStudyEntry;
}

const { content } = Astro.props;
const imgBase = import.meta.env.BASE_URL;
---

<section class="case-hero">
  <h1 class="case-title">{content.title}</h1>
  <p class="case-desc">{content.description}</p>
  <div class="case-teaser">
    <img
      class="case-teaser-img"
      src={imgBase + "/" + content.teaserImage.src.replace(/^\//, "")}
      alt={content.teaserImage.alt}
    />
  </div>
</section>

<style>
  .case-hero {
    padding: 0 24px;
    margin-top: 300px;
  }

  .case-title {
    font-family: "BDO Grotesk Black", "BDO Grotesk", "Inter", sans-serif;
    font-weight: 900;
    font-size: 120px;
    line-height: 1;
    margin: 0;
    color: var(--color-text);
  }

  .case-desc {
    max-width: 75%;
    margin: 24px 0 0;
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-text);
  }

  .case-teaser {
    margin-top: 140px;
  }

  .case-teaser-img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 1024px) {
    .case-desc {
      max-width: 85%;
    }
  }

  @media (max-width: 768px) {
    .case-title {
      font-size: 64px;
    }

    .case-desc {
      max-width: 100%;
      font-size: 28px;
    }
  }

  @media (max-width: 480px) {
    .case-title {
      font-size: 42px;
    }
  }
</style>
