---
import type { CaseNavItem } from "../../data/types";

interface Props {
  prev: CaseNavItem | null;
  next: CaseNavItem | null;
}

const { prev, next } = Astro.props;
const imgBase = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<nav class="case-nav" aria-label="Case study navigation">
  {prev && (
    <a href={imgBase + "/case/" + prev.slug} class="case-nav-link case-nav-prev">
      <span class="case-nav-label">
        <img
          class="case-nav-arrow"
          src={imgBase + "/images/icons/arrow-left.svg"}
          alt=""
        />
        Previous Project
      </span>
      <div class="case-nav-preview-wrap">
        <img
          class="case-nav-preview"
          src={imgBase + "/" + prev.image.src.replace(/^\//, "")}
          alt={prev.title}
        />
      </div>
    </a>
  )}
  {next && (
    <a href={imgBase + "/case/" + next.slug} class="case-nav-link case-nav-next">
      <span class="case-nav-label">
        Next Project
        <img
          class="case-nav-arrow case-nav-arrow--right"
          src={imgBase + "/images/icons/arrow-left.svg"}
          alt=""
        />
      </span>
      <div class="case-nav-preview-wrap">
        <img
          class="case-nav-preview"
          src={imgBase + "/" + next.image.src.replace(/^\//, "")}
          alt={next.title}
        />
      </div>
    </a>
  )}
</nav>

<style>
  .case-nav {
    display: flex;
    justify-content: space-between;
    padding: 0 24px;
  }

  .case-nav-link {
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-decoration: none;
    color: var(--color-text);
  }

  .case-nav-prev {
    align-items: flex-start;
  }

  .case-nav-next {
    align-items: flex-end;
  }

  .case-nav-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    transition: opacity 0.25s ease;
  }

  .case-nav-link:hover .case-nav-label {
    opacity: 0.5;
  }

  .case-nav-arrow {
    width: 24px;
    height: 24px;
    display: block;
  }

  .case-nav-arrow--right {
    transform: scaleX(-1);
  }

  .case-nav-preview-wrap {
    width: 240px;
    overflow: hidden;
  }

  .case-nav-preview {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 0.4s ease;
  }

  .case-nav-link:hover .case-nav-preview {
    transform: scale(1.06);
  }

  @media (max-width: 768px) {
    .case-nav-prev {
      display: none;
    }

    .case-nav {
      justify-content: flex-end;
      padding: 0 12px;
    }
  }
</style>
