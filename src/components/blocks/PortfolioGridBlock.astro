---
import type { PortfolioGridSectionContent } from "../../data/types";

interface Props {
  content: PortfolioGridSectionContent;
}

const { content } = Astro.props;
const imgBase = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section class="projects" id={content.id}>
  <h2 class="section-title">{content.title}</h2>
  <div class="cards-grid">
    {content.projects.map((project, i) => (
      project.disabled ? (
        <div class="card card--hidden" aria-hidden="true"></div>
      ) : (
        <a
          href={imgBase + "/" + project.href.replace(/^\//, "")}
          class="card"
          data-index={i}
        >
          <div class="card-image-wrap">
            <div class="card-image" style={{ aspectRatio: project.aspectRatio || "3/4" }}>
              <img
                src={imgBase + "/" + project.image.src.replace(/^\//, "")}
                alt={project.image.alt}
                loading="lazy"
              />
            </div>
          </div>
          <div class="card-body">
            <h3 class="card-title">{project.title}</h3>
            <p class="card-subtitle">{project.subtitle}</p>
          </div>
        </a>
      )
    ))}
  </div>
</section>

<script>
  const section = document.querySelector(".projects");
  const cards = section?.querySelectorAll(".card:not(.card--hidden)");
  if (!cards || cards.length === 0) { /* noop */ }

  if (cards && cards.length > 0) {
    const isMobile = window.innerWidth <= 768;

    if (!isMobile) {
      const staggerPx = 108;
      const totalMove = 120;

      const update = () => {
        const vh = window.innerHeight;

        cards.forEach((card) => {
          const rect = card.getBoundingClientRect();
          const fromBottom = vh - rect.top;
          const col = parseInt(card.getAttribute("data-index") || "0") % 3;
          const offset = col * staggerPx;
          const raw = (fromBottom - offset) / vh;
          const progress = Math.max(0, Math.min(1, raw));
          const eased = 1 - (1 - progress) * (1 - progress);
          const cardY = totalMove * (1 - eased);
          card.style.transform = `translateY(${cardY}px)`;
          const imgY = cardY * 1.5;
          card.style.setProperty("--img-parallax-y", `${imgY}px`);
        });
      };

      window.addEventListener("scroll", update, { passive: true });
      update();
    }

    const handleResize = () => {
      const newIsMobile = window.innerWidth <= 768;
      if (newIsMobile) {
        cards.forEach((card) => {
          card.style.removeProperty("transform");
          card.style.removeProperty("--img-parallax-y");
        });
      }
    };
    window.addEventListener("resize", handleResize, { passive: true });
  }
</script>

<style>
  .projects {
    padding: 0 24px 24px;
    margin-top: 192px;
    scroll-margin-top: 96px;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 400;
    line-height: 1.1;
    margin: 0 0 24px;
    color: var(--color-text);
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .card {
    display: block;
    text-decoration: none;
    color: var(--color-text);
    transform: translateY(120px);
  }

  .card--hidden {
    visibility: hidden;
    pointer-events: none;
  }

  .card-image-wrap {
    overflow: hidden;
    width: 100%;
  }

  .card-image {
    overflow: hidden;
    width: 100%;
  }

  .card-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    will-change: transform;
    transform: translateY(var(--img-parallax-y, 0px)) scale(1.12);
  }

  .card-body {
    padding-top: 24px;
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 8px;
    color: var(--color-text);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .card:hover .card-title {
    opacity: 0.6;
  }

  .card-subtitle {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.5;
    margin: 0;
    color: var(--color-text);
  }

  @media (max-width: 900px) {
    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .card {
      transform: none;
    }

    .card-image img {
      transform: scale(1.12);
    }
  }

  @media (max-width: 600px) {
    .cards-grid {
      grid-template-columns: 1fr;
    }

    .section-title {
      font-size: 36px;
    }
  }
</style>
