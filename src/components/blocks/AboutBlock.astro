---
import type { AboutSectionContent } from "../../data/types";

interface Props {
  content: AboutSectionContent;
}

const { content } = Astro.props;
---

<section class="about" id={content.id}>
  <div class="about-text">
    {content.body.map((p) => (
      <p class="about-paragraph">{p}</p>
    ))}
  </div>
</section>

<style>
  .about {
    padding: 0 24px;
    margin-top: 192px;
  }

  .about-text {
    max-width: 75%;
  }

  .about-paragraph {
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-text);
    margin: 0 0 24px;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 1024px) {
    .about-text {
      max-width: 85%;
    }
  }

  @media (max-width: 768px) {
    .about {
      padding: 0 12px;
    }

    .about-text {
      max-width: 100%;
    }

    .about-paragraph {
      font-size: 24px;
    }
  }
</style>
