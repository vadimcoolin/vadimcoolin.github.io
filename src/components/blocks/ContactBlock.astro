---
import type { ContactSectionContent } from "../../data/types";

interface Props {
  content: ContactSectionContent;
}

const { content } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const contactHref = baseUrl + "/" + content.link.href.replace(/^\//, "");
---

<section class="contact" id="contact">
  <h2 class="contact-title">
    {content.titleLines.map((line) => (
      <span class="contact-title-line">{line}</span>
    ))}
  </h2>
  <a href={contactHref} class="contact-button">
    {content.link.label}
  </a>
</section>

<style>
  .contact {
    padding: 0 24px;
    margin-top: 192px;
  }

  .contact-title {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 400;
    line-height: 1.1;
    margin: 0 0 14px;
    color: var(--color-text);
  }

  .contact-title-line {
    display: block;
  }

  .contact-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 232px;
    height: 56px;
    padding: 0 32px;
    background: #000;
    color: var(--color-bg);
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1;
    text-decoration: none;
    border: none;
    border-radius: 9999px;
    transition: background 0.25s ease;
    cursor: pointer;
  }

  .contact-button:hover {
    background: #22c55e;
  }

  @media (max-width: 600px) {
    .contact-title {
      font-size: 36px;
    }
  }
</style>