---
import type { ContactSectionContent } from "../../data/types";

interface Props {
  content: ContactSectionContent;
}

const { content } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const contactHref = baseUrl + "/" + content.link.href.replace(/^\//, "");
---

<section class="contact" id="contact">
  <h2 class="contact-title">{content.title}</h2>
  <a href={contactHref} class="contact-link">{content.link.label}</a>
</section>

<style>
  .contact {
    padding: 0 24px;
    margin-top: 200px;
  }

  .contact-title {
    font-family: var(--font-heading);
    font-size: 54px;
    font-weight: 400;
    line-height: 1.1;
    margin: 0 0 24px;
    color: var(--color-text);
  }

  .contact-link {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    position: relative;
    line-height: 1;
  }

  .contact-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1px;
    background: var(--color-text);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .contact-link:hover::after {
    transform: scaleX(1);
  }

  @media (max-width: 600px) {
    .contact-title {
      font-size: 36px;
    }
  }
</style>
