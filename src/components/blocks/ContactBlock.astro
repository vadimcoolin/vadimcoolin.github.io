---
import type { ContactSectionContent } from "../../data/types";

interface Props {
  content: ContactSectionContent;
}

const { content } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const contactHref = baseUrl + "/" + content.link.href.replace(/^\//, "");
---

<section class="contact" id="contact">
  <h2 class="contact-title">{content.title}</h2>
  <a href={contactHref} class="contact-link">
    {content.link.label}
    <img
      class="contact-link-arrow"
      src={baseUrl + "/images/icons/arrow-left.svg"}
      alt=""
    />
  </a>
</section>

<style>
  .contact {
    padding: 0 24px;
    margin-top: 200px;
  }

  .contact-title {
    font-family: var(--font-heading);
    font-size: 54px;
    font-weight: 400;
    line-height: 1.1;
    margin: 0 0 14px;
    color: var(--color-text);
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    line-height: 1;
    transition: opacity 0.25s ease;
  }

  .contact-link:hover {
    opacity: 0.5;
  }

  .contact-link-arrow {
    width: 24px;
    height: 24px;
    display: block;
    transform: scaleX(-1);
  }

  @media (max-width: 600px) {
    .contact-title {
      font-size: 36px;
    }
  }
</style>
