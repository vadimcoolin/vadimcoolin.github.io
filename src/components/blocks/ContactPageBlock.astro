---
import type { ContactPageContent } from "../../data/types";

interface Props {
  content: ContactPageContent;
}

const { content } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");

const resolveHref = (href?: string) => {
  if (!href) return "";
  if (href.startsWith("http") || href.startsWith("tel:") || href.startsWith("mailto:")) return href;
  return `${baseUrl}${href}`;
};

const isExternal = (href?: string) => href?.startsWith("http");
---

<section class="contact-page">
  <div class="contact-page-inner">
    <h1 class="contact-page-title">{content.title}</h1>
    <div class="contact-page-blocks">
      <div class="contact-block">
        {content.info.map((item) =>
          item.href ? (
            <a
              href={resolveHref(item.href)}
              class="contact-page-link"
              target={isExternal(item.href) ? "_blank" : undefined}
              rel={isExternal(item.href) ? "noopener noreferrer" : undefined}
            >
              {item.label}
            </a>
          ) : (
            <span class="contact-page-text">{item.label}</span>
          ),
        )}
      </div>
      <div class="contact-block">
        {content.social.map((item) => (
          <a
            href={resolveHref(item.href)}
            class="contact-page-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            {item.label}
          </a>
        ))}
      </div>
      <div class="contact-block">
        {content.otherLinks.map((item) => (
          <a
            href={resolveHref(item.href)}
            class="contact-page-link"
            target={isExternal(item.href) ? "_blank" : undefined}
            rel={isExternal(item.href) ? "noopener noreferrer" : undefined}
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .contact-page {
    padding: 0 24px;
    margin-top: 300px;
  }

  .contact-page-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .contact-page-title {
    font-family: "BDO Grotesk Black", "BDO Grotesk", "Inter", sans-serif;
    font-weight: 900;
    font-size: 120px;
    line-height: 1;
    margin: 0;
    color: var(--color-text);
    text-transform: uppercase;
  }

  .contact-page-blocks {
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  .contact-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }

  .contact-page-link {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 400;
    color: var(--color-text);
    text-decoration: none;
    position: relative;
    line-height: 1;
    width: fit-content;
  }

  .contact-page-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1px;
    background: var(--color-text);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .contact-page-link:hover::after {
    transform: scaleX(1);
  }

  .contact-page-text {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 400;
    color: var(--color-text);
    line-height: 1;
  }

  @media (max-width: 900px) {
    .contact-page-inner {
      grid-template-columns: 1fr;
      gap: 64px;
    }

    .contact-page-title {
      font-size: 64px;
    }
  }

  @media (max-width: 480px) {
    .contact-page-title {
      font-size: 42px;
    }
  }
</style>
