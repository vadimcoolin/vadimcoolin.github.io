---
import Section from "../ui/Section.astro";
import SectionIntro from "./subblocks/SectionIntro.astro";
import type { ThreeColumnCardsSectionContent } from "../../data/types";

interface Props {
  content: ThreeColumnCardsSectionContent;
}

const { content } = Astro.props;
const { title, body, bodyMargins, bodyMarginBottom } = content.intro;
---

<Section
  id={content.id}
  topSpacing={content.topSpacing}
  surface={content.surface}
  backgroundMedia={content.backgroundMedia}
  container={content.container}
  containerClass={content.containerClass}
>
  <SectionIntro
    title={title}
    body={body}
    bodyMargins={bodyMargins}
    bodyMarginBottom={bodyMarginBottom}
  />
  <div class="grid grid-cols-1 gap-14 lg:grid-cols-3">
    {
      content.cards.map((card) => (
        <article class="min-w-0">
          <div class="aspect-[390/312] w-full overflow-hidden rounded-[var(--radius-image)] shadow-[var(--shadow-default)]">
            <img
              src={card.media.src}
              alt={card.media.alt}
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="pl-8 pt-8">
            <h3 class="h4">{card.title}</h3>
            <p class="mt-6">{card.body}</p>
          </div>
        </article>
      ))
    }
  </div>
</Section>
