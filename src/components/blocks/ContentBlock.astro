---
import Button from "../ui/Button.astro";
import Section from "../ui/Section.astro";
import type { ContentSectionContent } from "../../data/types";

interface Props {
  content: ContentSectionContent;
}

const { content } = Astro.props;

const titleAsH1 = content.titleAsH1 === true;
const hasTitle = Boolean(content.title?.trim());
const hasBody = Boolean(content.body?.length);
const hasAction = Boolean(content.action?.label?.trim() && content.action?.href?.trim());
const hasAny = hasTitle || hasBody || hasAction;
---

{
  hasAny && (
    <Section
      id={content.id}
      topSpacing={content.topSpacing}
      surface={content.surface}
      backgroundMedia={content.backgroundMedia}
      container={content.container}
      containerClass={content.containerClass}
    >
      <div class="grid grid-cols-12 gap-6">
        <div class="col-span-10 col-start-2 px-0 lg:px-[60px]">
          <div class="flex flex-col gap-10">
            {
              hasTitle &&
                (titleAsH1 ? (
                  <h1 class="h1">{content.title}</h1>
                ) : (
                  <h2 class="h2">{content.title}</h2>
                ))
            }
            {hasBody && (
              <div>
                {content.body!.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </div>
            )}
            {hasAction && (
              <div>
                <Button href={content.action!.href}>{content.action!.label}</Button>
              </div>
            )}
          </div>
        </div>
      </div>
    </Section>
  )
}
