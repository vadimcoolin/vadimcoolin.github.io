---
import type { HeroSectionContent } from "../../data/types";

interface Props {
  content: HeroSectionContent;
}

const { content } = Astro.props;
const logoUrl = import.meta.env.BASE_URL.replace(/\/$/, "") + "/" + content.logo.src.replace(/^\//, "");
---

<section class="hero">
  <div class="hero-logo">
    <img
      src={logoUrl}
      alt={content.logo.alt}
      class="hero-logo-img"
      fetchpriority="high"
    />
  </div>
</section>

<style>
  .hero {
    min-height: 100dvh;
    padding: calc(85dvh - 24px - (100vw - 48px) * 0.202) 24px 0;
    box-sizing: border-box;
  }

  .hero-logo {
    width: 100%;
  }

  .hero-logo-img {
    width: 100%;
    height: auto;
  }

  @media (max-width: 768px) {
    .hero {
      padding: calc(85dvh - 24px - (100vw - 32px) * 0.202) 16px 0;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: calc(85dvh - 24px - (100vw - 24px) * 0.202) 12px 0;
    }
  }
</style>
