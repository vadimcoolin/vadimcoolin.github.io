---
import type { LogoMarqueeSectionContent } from "../../data/types";

interface Props {
  content: LogoMarqueeSectionContent;
}

const { content } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const allLogos = [...content.logos, ...content.logos];
---

<section class="marquee" aria-label="Brand logos">
  <div class="marquee-track">
    <div class="marquee-content">
      {allLogos.map((logo, i) => (
        <img
          class="marquee-logo"
          src={baseUrl + "/" + logo.src.replace(/^\//, "")}
          alt={i < content.logos.length ? logo.alt : ""}
          loading="eager"
        />
      ))}
    </div>
  </div>
</section>

<style>
  .marquee {
    margin-top: 96px;
    padding: 0 24px;
    overflow: hidden;
  }

  .marquee-track {
    height: clamp(56px, 6.25vw, 120px);
    overflow: hidden;
  }

  .marquee-content {
    display: inline-flex;
    align-items: center;
    gap: 64px;
    height: 100%;
    animation: marquee-scroll 30s linear infinite;
  }

  .marquee-logo {
    height: 55%;
    width: auto;
    flex-shrink: 0;
    filter: brightness(0);
    transition: filter 0.25s ease;
  }

  .marquee-logo:hover {
    filter: brightness(0) invert(57.5%);
  }

  @keyframes marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-content {
      animation: none;
    }
  }
</style>
