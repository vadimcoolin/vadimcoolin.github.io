---
import HeroBlock from "../components/blocks/HeroBlock.astro";
import TeaserBlock from "../components/blocks/TeaserBlock.astro";
import PortfolioGridBlock from "../components/blocks/PortfolioGridBlock.astro";
import ContactBlock from "../components/blocks/ContactBlock.astro";
import {
  heroSection,
  teaserSection,
  projectsSection,
  contactSection,
  homePageMetaDescription,
} from "../data/pages/home";
import PageTemplate from "../layouts/PageTemplate.astro";
---

<PageTemplate
  title="Vadim Coolin"
  description={homePageMetaDescription}
>
  <HeroBlock content={heroSection} />
  <TeaserBlock content={teaserSection} />
  <PortfolioGridBlock content={projectsSection} />
  <ContactBlock content={contactSection} />
</PageTemplate>
