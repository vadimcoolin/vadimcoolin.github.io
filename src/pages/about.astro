---
import AboutBlock from "../components/blocks/AboutBlock.astro";
import LogoMarqueeBlock from "../components/blocks/LogoMarqueeBlock.astro";
import IndustryBlock from "../components/blocks/IndustryBlock.astro";
import ContactBlock from "../components/blocks/ContactBlock.astro";
import PageTemplate from "../layouts/PageTemplate.astro";
import { aboutPageContent, logosSection, industrySection } from "../data/pages/about";
import { contactSection } from "../data/pages/home";
---

<PageTemplate title="About — Vadim Coolin">
  <AboutBlock content={aboutPageContent} />
  <LogoMarqueeBlock content={logosSection} />
  <IndustryBlock content={industrySection} />
  <ContactBlock content={contactSection} />
</PageTemplate>
